---
import { LOGO_IMAGE, SITE } from "@config";
import LinkButton from "./LinkButton.astro";

export interface Props {
  activeNav?: "posts" | "contact" | "about" | "search" | "tags" | "courses";
}

const { activeNav } = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 glass border-b border-skin-line-light">
  <a id="skip-to-content" href="#main-content">Skip to content</a>
  <div class="nav-container container-wide">
    <div class="top-nav-wrap">
      <a href="/" class="logo group flex items-center gap-3 whitespace-nowrap">
        <div class="logo-icon">
          {
            LOGO_IMAGE.enable ? (
              <img
                src={`/assets/${LOGO_IMAGE.svg ? "logo.svg" : "logo.png"}`}
                alt={SITE.title}
                width={LOGO_IMAGE.width}
                height={LOGO_IMAGE.height}
                class="hover-lift"
              />
            ) : (
              <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-skin-gradient-start to-skin-gradient-end flex items-center justify-center text-white font-bold text-xl hover-lift">
                PK
              </div>
            )
          }
        </div>
        <span class="text-xl font-bold text-skin-base group-hover:text-skin-accent transition-colors">
          {SITE.title}
        </span>
      </a>
      <nav id="nav-menu">
        <button
          class="hamburger-menu rounded-lg p-2 hover:bg-skin-card md:hidden outline-2 outline-offset-1 outline-skin-fill focus-visible:no-underline focus-visible:outline-dashed"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="menu-icon"
          >
            <line x1="3" y1="6" x2="21" y2="6" class="line top"></line>
            <line x1="3" y1="12" x2="21" y2="12" class="line middle"></line>
            <line x1="3" y1="18" x2="21" y2="18" class="line bottom"></line>
            <line x1="18" y1="6" x2="6" y2="18" class="close left"></line>
            <line x1="6" y1="6" x2="18" y2="18" class="close right"></line>
          </svg>
        </button>
        <ul id="menu-items" class="menu-items display-none md:flex">
          <li>
            <a href="/posts/" class={`nav-link ${activeNav === "posts" ? "active" : ""}`}>
              <span>Posts</span>
            </a>
          </li>
          <li>
            <a href="/courses/" class={`nav-link ${activeNav === "courses" ? "active" : ""}`}>
              <span>Courses</span>
            </a>
          </li>
          <li>
            <a href="/contact/" class={`nav-link ${activeNav === "contact" ? "active" : ""}`}>
              <span>Contact</span>
            </a>
          </li>
          <li>
            <a href="/about/" class={`nav-link ${activeNav === "about" ? "active" : ""}`}>
              <span>About</span>
            </a>
          </li>
          <li class="nav-separator"></li>
          <li>
            <LinkButton
              href="/search/"
              className={`nav-icon-btn ${activeNav === "search" ? "active" : ""}`}
              ariaLabel="search"
              title="Search"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="11" cy="11" r="8"></circle>
                <path d="m21 21-4.35-4.35"></path>
              </svg>
              <span class="sr-only">Search</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li>
                <button
                  id="theme-btn"
                  class="nav-icon-btn"
                  title="Toggle theme"
                  aria-label="Toggle theme"
                  aria-live="polite"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" id="moon-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
                  </svg>
                  <svg xmlns="http://www.w3.org/2000/svg" id="sun-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"></circle>
                    <line x1="12" y1="1" x2="12" y2="3"></line>
                    <line x1="12" y1="21" x2="12" y2="23"></line>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                    <line x1="1" y1="12" x2="3" y2="12"></line>
                    <line x1="21" y1="12" x2="23" y2="12"></line>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                  </svg>
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
</header>
<div class="header-spacer"></div>

<style>
  .header-spacer {
    @apply h-16 md:h-20;
  }

  #skip-to-content {
    @apply absolute -top-full left-16 z-50 bg-skin-accent px-4 py-2 rounded-lg text-white font-medium transition-all focus:top-4 shadow-lg;
  }
  
  
  .top-nav-wrap {
    @apply flex items-center justify-between h-16 md:h-20;
  }
  
  .logo {
    @apply z-10;
  }
  
  .hamburger-menu svg {
    @apply h-6 w-6;
  }

  nav {
    @apply relative;
  }
  
  .menu-items {
    @apply absolute right-0 top-12 bg-skin-fill border border-skin-line rounded-xl shadow-lg p-2 min-w-[200px]
    md:relative md:top-0 md:flex md:items-center md:gap-1 md:bg-transparent md:border-0 md:shadow-none md:p-0 md:min-w-0;
  }
  
  .menu-items li {
    @apply block md:inline-block;
  }
  
  .nav-link {
    @apply block px-4 py-2 rounded-lg text-skin-base font-medium transition-all duration-200
    hover:bg-skin-card hover:text-skin-accent
    md:px-3 md:py-1.5;
  }
  
  .nav-link.active {
    @apply text-skin-accent bg-skin-accent bg-opacity-10;
  }
  
  .nav-link span {
    @apply relative;
  }
  
  .nav-link.active span::after {
    @apply content-[''] absolute -bottom-0.5 left-0 right-0 h-0.5 bg-skin-accent rounded-full;
  }
  
  .nav-separator {
    @apply hidden md:block w-px h-6 mx-2;
    background-color: rgb(var(--color-border));
  }
  
  .nav-icon-btn {
    @apply flex items-center justify-center w-10 h-10 rounded-lg text-skin-base transition-all duration-200
    hover:bg-skin-card hover:text-skin-accent outline-2 outline-offset-1 outline-skin-fill focus-visible:no-underline focus-visible:outline-dashed;
  }
  
  .nav-icon-btn.active {
    @apply text-skin-accent;
  }

  .menu-icon line {
    @apply transition-all duration-300 ease-out;
    transform-origin: center;
  }
  
  .menu-icon .close {
    opacity: 0;
  }
  
  .menu-icon.is-active .line {
    opacity: 0;
  }
  
  .menu-icon.is-active .close {
    opacity: 1;
  }
  
  @media (max-width: 767px) {
    .menu-items li:not(:last-child) {
      @apply border-b border-skin-line-light;
    }
  }
</style>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector(".hamburger-menu");
    const menuIcon = document.querySelector(".menu-icon");
    const menuItems = document.querySelector("#menu-items");

    menuBtn?.addEventListener("click", () => {
      const menuExpanded = menuBtn.getAttribute("aria-expanded") === "true";
      menuIcon?.classList.toggle("is-active");
      menuBtn.setAttribute("aria-expanded", menuExpanded ? "false" : "true");
      menuBtn.setAttribute(
        "aria-label",
        menuExpanded ? "Open Menu" : "Close Menu"
      );
      menuItems?.classList.toggle("display-none");
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!menuBtn?.contains(target) && !menuItems?.contains(target)) {
        menuIcon?.classList.remove("is-active");
        menuBtn?.setAttribute("aria-expanded", "false");
        menuBtn?.setAttribute("aria-label", "Open Menu");
        menuItems?.classList.add("display-none");
      }
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);
</script>